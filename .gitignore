# Ignore everything by default
/*

# Allow TP directories and their contents
!/TP1-Linear Regression/
!/TP2-Regression and Cross Validation for Network Data Analysis/
!/TP4-Clustering/
!/TP5_PCA_Anomaly/
!/TP6-NeuralNetworks/

# Allow all files in TP directories
!/TP1-Linear Regression/**
!/TP2-Regression and Cross Validation for Network Data Analysis/**
!/TP4-Clustering/**
!/TP5_PCA_Anomaly/**
!/TP6-NeuralNetworks/**

# Exclude large dataset files from TP4
TP4-Clustering/*.txt

# Ignore Python cache and virtual environments
**/__pycache__/
**/*.py[cod]
**/*.pyc
**/venv/
**/env/
**/.venv/

# Ignore Jupyter checkpoints
**/.ipynb_checkpoints/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE settings
.vscode/
.idea/
*.swp
*.swo

# Ignore egg-info, dist, and build directories
**/*.egg-info/
**/dist/
**/build/
